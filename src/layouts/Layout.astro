---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;

const navItems = [
  { href: '/', title: 'Home' },
  { href: '/about', title: 'Über mich' },
  { href: '/kurse', title: 'Kurse' },
  { href: '/agb', title: "AGB's & dein Yoga" },
  { href: '/kontakt', title: 'Kontakt' }
];

const currentPath = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="de" class="font-lato bg-white text-gray-900 scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Herzenergie Yoga - YOGA IN GEORGSMARIENHÜTTE" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&display=swap" rel="stylesheet">

		<title>{title} | Herzenergie Yoga</title>
	</head>
	<body class="min-h-screen flex flex-col font-light">
    <!-- Header/Nav -->
    <header class="bg-white sticky top-0 z-50 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="flex-shrink-0 flex items-center">
            <a href="/" class="text-3xl md:text-4xl font-light tracking-[0.15em] text-gray-800 hover:text-gray-500 transition-colors uppercase">
              Herzenergie Yoga
            </a>
          </div>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex space-x-12">
            {navItems.map(item => (
              <a
                href={item.href}
                class={`text-sm tracking-[0.1em] font-light transition-colors uppercase
                  ${(currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)))
                    ? 'text-gray-900 border-b border-gray-900 pb-1'
                    : 'text-gray-500 hover:text-gray-900'
                  }`}
              >
                {item.title}
              </a>
            ))}
          </nav>

          <!-- Mobile menu button -->
          <div class="md:hidden flex items-center w-full justify-center border-t border-gray-100 pt-4 mt-2">
            <button id="mobile-menu-btn" class="text-gray-500 hover:text-gray-900 focus:outline-none p-2 flex items-center gap-2 uppercase tracking-widest text-sm">
              <span>Menü</span>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-100">
        <div class="px-4 pt-2 pb-6 space-y-4 text-center">
          {navItems.map(item => (
            <a
              href={item.href}
              class={`block px-3 py-2 text-sm uppercase tracking-widest font-light
                ${(currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)))
                  ? 'text-gray-900'
                  : 'text-gray-500 hover:text-gray-900'
                }`}
            >
              {item.title}
            </a>
          ))}
        </div>
      </div>
    </header>

    <!-- Header Image -->
    <div class="w-full h-[35vh] md:h-[45vh] relative overflow-hidden bg-white">
      <img
        src="/img/header.jpeg"
        alt="Herzenergie Yoga"
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Main Content -->
		<main class="flex-grow max-w-4xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="prose prose-lg md:prose-xl prose-stone mx-auto text-center
        prose-headings:font-light prose-headings:text-gray-800 prose-headings:tracking-wider
        prose-h1:text-3xl md:prose-h1:text-4xl prose-h1:mb-12 prose-h1:uppercase
        prose-h2:text-2xl prose-h3:text-xl
        prose-a:text-gray-500 prose-a:no-underline hover:prose-a:text-gray-900 hover:prose-a:underline
        prose-p:leading-[1.8] prose-p:text-gray-600 prose-p:font-light
        prose-blockquote:border-l-gray-300 prose-blockquote:bg-gray-50 prose-blockquote:p-6 prose-blockquote:rounded-none prose-blockquote:italic prose-blockquote:text-gray-500 prose-blockquote:font-light
        prose-img:rounded-none prose-img:shadow-sm prose-img:mx-auto
        max-w-none">
			  <slot />
      </div>
		</main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-100 mt-auto py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center gap-4">
        <h3 class="text-lg font-light tracking-[0.2em] text-gray-800 uppercase mb-2">Herzenergie Yoga</h3>
        <p class="text-gray-500 font-light tracking-wider text-sm">YOGA IN GEORGSMARIENHÜTTE</p>
        <p class="text-gray-500 font-light tracking-wider text-sm">
          <a href="https://herzenergie-yoga.de" class="hover:text-gray-900 transition-colors">herzenergie-yoga.de</a>
        </p>
        <p class="text-gray-500 font-light tracking-wider text-sm mb-6">0163-2876265</p>

        <p class="text-sm text-gray-400">
          Copyright &copy; Herzenergie Yoga {new Date().getFullYear()}
        </p>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');

      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }
    </script>
	</body>
</html>
