---
import Layout from '../../layouts/Layout.astro';

const yogastile = [
  {
    href: '/kurse/hatha-yoga',
    name: 'Hatha Yoga',
    tagline: 'Kraftvoll & sanft im Gleichgewicht',
    info: 'Freitag · Sonntag',
  },
  {
    href: '/kurse/yin-yoga',
    name: 'Yin Yoga',
    tagline: 'Still werden, tief loslassen',
    info: 'Samstag',
  },
  {
    href: '/kurse/waldyoga',
    name: 'Waldyoga',
    tagline: 'Atme. Spüre. Verbinde dich mit der Natur.',
    info: 'Sommerferien 2026',
  },
];
---

<Layout title="Kurse">
  <h1>Kurse</h1>

  <p>Schön, dass du hier bist. Hier findest du einen Überblick über meine Yogakurse – jeder mit seinem eigenen Charakter, jeder mit ganz viel Raum für dich.</p>
  <p>Wähle einfach den Stil, der dich gerade ruft, und erfahre mehr.</p>

  <div class="not-prose my-12 grid grid-cols-1 sm:grid-cols-3 gap-px bg-brand-secondary/20">
    {yogastile.map((stil) => (
      <a href={stil.href} class="group bg-brand-bg px-6 py-10 text-center space-y-5 hover:bg-white transition-colors">
        <h3 class="text-5xl font-alex-brush text-brand-primary font-normal min-h-24 flex items-center justify-center">{stil.name}</h3>
        <p class="text-brand-text font-light tracking-wide text-sm leading-relaxed italic">{stil.tagline}</p>
        <p class="text-xs tracking-[0.2em] uppercase text-brand-text/60 font-light">{stil.info}</p>
        <div class="pt-5 mt-5 border-t border-brand-secondary/20">
          <span class="text-brand-primary font-antic-didone tracking-[0.15em] text-sm uppercase group-hover:underline underline-offset-4">Mehr erfahren</span>
        </div>
      </a>
    ))}
  </div>
</Layout>
